<!-- GCS OFFBOARD -->
<launch>
  <!-- ====== ARGS ====== -->
  <arg name="sim" default="true" />
  <arg name="record_bag" default="$(env RECORD_BAGS)" />
  <arg name="gui" default="$(env GCS_GUI false)" />

  <!-- set "onboard_all" or "onboard_local_offboard_global" -->
  <arg name="autonomy_split_type" default="onboard_all" />

  <!-- ======== GUI ======== -->

  <group if="$(var gui)">
    <node pkg="rqt_gui" exec="rqt_gui"
      args="--perspective-file $(find-pkg-share desktop_bringup)/config/gcs.perspective --force-discover"
      output="screen" respawn="true" respawn_delay="1" />
  </group>
  <!-- ===================== -->

</launch>
